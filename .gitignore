# ===========================================
# RailSafeNet_LiDAR .gitignore
# ===========================================

# -------------------------------------------
# 1. Datasets & Large Files (MUST NOT BE DELETED)
# -------------------------------------------
# Video datasets
assets/crop/
assets/crop2/
*.mp4
*.avi
*.mov

# Model weights (large binary files)
assets/models_pretrained/
*.pth
*.pt
*.onnx
*.engine
yolov8n.pt

# Dataset directories
assets/pilsen_railway_dataset/
assets/rs19val/
rs19_val/
railway_dataset/

# Calibration cache
assets/calibration_cache/

# -------------------------------------------
# 2. IDE & Editor Settings
# -------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.vscode

# -------------------------------------------
# 3. Python Cache & Build Artifacts
# -------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
wheels/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# -------------------------------------------
# 4. Virtual Environments
# -------------------------------------------
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# -------------------------------------------
