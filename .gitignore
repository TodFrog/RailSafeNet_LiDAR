# ===========================================
# RailSafeNet_LiDAR .gitignore
# Production-ready configuration
# ===========================================

# -------------------------------------------
# 1. Archive Directory (Development/Training files)
# -------------------------------------------
.archive/

# -------------------------------------------
# 2. Large Files & Datasets
# -------------------------------------------
# Video files
assets/crop/
assets/crop2/
*.mp4
*.avi
*.mov

# Model weights (binary files)
assets/models_pretrained/
*.pth
*.pt
*.onnx
*.engine

# Dataset directories
assets/pilsen_railway_dataset/
assets/rs19val/
rs19_val/
railway_dataset/

# Calibration cache
assets/calibration_cache/

# -------------------------------------------
# 3. Results & Output (Regenerable)
# -------------------------------------------
results/
output/
comparison_results/
evaluation_results/
enhanced_results/
fixed_results/
robust_results/
video_results/
optimized_results/
simple_results/
class_analysis/

# -------------------------------------------
# 4. Python Cache & Build
# -------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
dist/
build/
wheels/
.mypy_cache/
.pytest_cache/

# -------------------------------------------
# 5. Virtual Environments
# -------------------------------------------
.env
.venv
env/
venv/
ENV/

# -------------------------------------------
# 6. IDE & Editor
# -------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -------------------------------------------
# 7. Testing & Coverage
# -------------------------------------------
.coverage
htmlcov/
*.cover
.hypothesis/

# -------------------------------------------
# 8. Development Tools
# -------------------------------------------
# Claude Code
.claude/

# Specify
.specify/

# W&B
wandb/

# Jupyter
.ipynb_checkpoints/

# -------------------------------------------
# 9. Logs & Temp Files
# -------------------------------------------
*.log
logs/
*.tmp
temp/

# -------------------------------------------
# 10. OS Files
# -------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------
# KEEP TRACKED (Essential Production Files)
# -------------------------------------------
# videoAssessor_final.py - Main entry point
# videoAssessor.py - Base class
# src/ - Core modules
# config/ - Configuration files
# docker/ - Docker deployment
# scripts/metrics_filtered_cls.py - Required import
# scripts/run_*.sh - Launch scripts
# scripts/build_docker.sh - Docker build
# CLAUDE.md - Project guidelines
# README.md - Documentation
# requirements.txt - Dependencies
