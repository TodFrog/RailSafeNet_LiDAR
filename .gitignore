# -------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------
# 8. Jupyter Notebook
# -------------------------------------------
.ipynb_checkpoints

# -------------------------------------------
# 9. W&B (Weights & Biases)
# -------------------------------------------
wandb/

